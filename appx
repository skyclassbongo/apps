<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="image/icon.jpg" />
  <title>BAILA TV MAX - Furahia Mpira, Tamthilia, Magazeti na Tetesi za Soka</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet" />
  <style>
    :root {
      --primary-color: #0b57d0;
      --secondary-color: #ff6b6b;
      --accent-color: #4ecdc4;
      --dark-color: #2c3e50;
      --light-color: #f9f9fa;
    }
    
    body {
      background-color: var(--light-color);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      overflow-x: hidden;
    }

    .app-icon {
      width: 100px;
      height: 100px;
      border-radius: 20px;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
    }
    
    .app-icon:hover {
      transform: scale(1.05) rotate(5deg);
      box-shadow: 0 15px 30px rgba(0,0,0,0.2);
    }

    .screenshot {
      height: 250px;
      object-fit: cover;
      border-radius: 12px;
      width: 100%;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      transition: all 0.3s ease;
      cursor: pointer;
    }
    
    .screenshot:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.2);
    }

    .tag {
      border: 1px solid #ccc;
      border-radius: 20px;
      padding: 5px 12px;
      margin-right: 10px;
      font-size: 14px;
      transition: all 0.3s ease;
      background: white;
    }
    
    .tag:hover {
      background: var(--primary-color);
      color: white;
      transform: scale(1.05);
    }

    .download-btn {
      background: linear-gradient(135deg, var(--primary-color), #4a89dc);
      color: white;
      border-radius: 30px;
      padding: 12px 30px;
      font-weight: bold;
      border: none;
      box-shadow: 0 5px 15px rgba(11, 87, 208, 0.3);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    
    .download-btn:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 25px rgba(11, 87, 208, 0.4);
    }
    
    .download-btn:active {
      transform: translateY(1px);
    }
    
    .download-btn::after {
      content: '';
      position: absolute;
      top: -50%;
      left: -60%;
      width: 200%;
      height: 200%;
      background: rgba(255,255,255,0.2);
      transform: rotate(30deg);
      transition: all 0.3s ease;
    }
    
    .download-btn:hover::after {
      left: 100%;
    }

    .section-title {
      font-weight: 600;
      margin-top: 30px;
      position: relative;
      display: inline-block;
      color: var(--dark-color);
    }
    
    .section-title::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 50px;
      height: 3px;
      background: var(--primary-color);
      border-radius: 3px;
    }

    .info-box {
      text-align: center;
      padding: 10px;
      border-radius: 12px;
      background: white;
      box-shadow: 0 3px 10px rgba(0,0,0,0.05);
      transition: all 0.3s ease;
    }
    
    .info-box:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    
    .info-box small {
      display: block;
      color: #666;
    }

    .like-button {
      display: flex;
      align-items: center;
      gap: 5px;
      transition: all 0.3s ease;
      border-radius: 20px;
    }
    
    .like-button:hover {
      background: rgba(255, 107, 107, 0.1);
      transform: scale(1.05);
    }
    
    .like-button:active {
      transform: scale(0.95);
    }

    /* Floating animation */
    @keyframes float {
      0% { transform: translateY(0px); }
      50% { transform: translateY(-10px); }
      100% { transform: translateY(0px); }
    }
    
    .floating {
      animation: float 3s ease-in-out infinite;
    }
    
    /* Pulse animation */
    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.05); }
      100% { transform: scale(1); }
    }
    
    .pulse {
      animation: pulse 2s infinite;
    }
    
    /* Background elements */
    .bg-element {
      position: absolute;
      border-radius: 50%;
      opacity: 0.1;
      z-index: -1;
    }
    
    .bg-1 {
      width: 300px;
      height: 300px;
      background: var(--primary-color);
      top: -100px;
      right: -100px;
    }
    
    .bg-2 {
      width: 200px;
      height: 200px;
      background: var(--secondary-color);
      bottom: -50px;
      left: -50px;
    }
    
    /* Rating stars */
    .rating-stars {
      color: #ffc107;
      font-size: 1.2rem;
    }
    
    /* Feature cards */
    .feature-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.05);
      transition: all 0.3s ease;
      border-left: 4px solid var(--primary-color);
    }
    
    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
    
    .feature-icon {
      font-size: 2rem;
      color: var(--primary-color);
      margin-bottom: 15px;
    }
    
    /* Footer */
    .footer {
      background: var(--dark-color);
      color: white;
      padding: 30px 0;
      margin-top: 50px;
    }
    
    /* Modal for screenshots */
    .modal-img {
      max-height: 80vh;
      object-fit: contain;
    }
  </style>
</head>
<body>
  <!-- Background elements -->
  <div class="bg-element bg-1"></div>
  <div class="bg-element bg-2"></div>

  <div class="container py-4 animate__animated animate__fadeIn">
    <!-- App Header -->
    <div class="d-flex align-items-start animate__animated animate__fadeInDown">
      <img src="image/icon.jpg" alt="App Icon" class="app-icon me-3 floating" />
      <div>
        <h4 class="mb-0">SOKA TV MAX</h4>
        <small class="text-primary">Sports, Entertainment, News</small><br />
        <small>There is No Ads</small>
      </div>
    </div>

    <!-- Info Line -->
    <div class="mt-3 d-flex gap-4 animate__animated animate__fadeIn animate__delay-1s">
      <div class="info-box"><strong>4.6</strong> <span class="rating-stars">★★★★★</span><small>2K reviews</small></div>
      <div class="info-box"><strong>29 MB</strong><small>App size</small></div>
      <div class="info-box"><strong>3+</strong><small>Rated for ages</small></div>
    </div>

    <!-- Download Button -->
    <a href="soka-tv-max.apk" class="btn download-btn mt-3 w-100 animate__animated animate__pulse animate__delay-2s">
      <i class="fas fa-download me-2"></i> Download Now
    </a>

    <!-- Features -->
    <div class="row mt-5 animate__animated animate__fadeIn animate__delay-1s">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fas fa-futbol"></i>
          </div>
          <h5>Mpira wa Kufurahisha</h5>
          <p>Furahia mechi za soka kutoka ulimwenguni pote moja kwa moja.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fas fa-film"></i>
          </div>
          <h5>Tamthilia Bora</h5>
          <p>Video na vipindi vya kuvutia kwa burudani yako.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon">
            <i class="fas fa-newspaper"></i>
          </div>
          <h5>Habari za Soka</h5>
          <p>Pata habari na magazeti ya soka kila siku.</p>
        </div>
      </div>
    </div>

    <!-- Screenshots -->
    <div class="mt-4 animate__animated animate__fadeIn animate__delay-1s">
      <h5 class="section-title">Screenshots</h5>
      <div class="row">
        <div class="col-md-4">
          <img src="image/1.jpg" class="screenshot" alt="Screenshot 1" data-toggle="modal" data-target="#screenshotModal" data-img="image/1.jpg" />
        </div>
        <div class="col-md-4">
          <img src="image/2.jpg" class="screenshot" alt="Screenshot 2" data-toggle="modal" data-target="#screenshotModal" data-img="image/2.jpg" />
        </div>
        <div class="col-md-4">
          <img src="image/3.jpg" class="screenshot" alt="Screenshot 3" data-toggle="modal" data-target="#screenshotModal" data-img="image/3.jpg" />
        </div>
      </div>
    </div>

    <!-- About Section -->
    <div class="mt-4 animate__animated animate__fadeIn animate__delay-1s">
      <h5 class="section-title">About this app</h5>
      <p>Furahia Mpira, Tamthilia, Magazeti ya kila siku, na Tetesi za Soka moja kwa moja kupitia BAILA TV MAX. Tunaweka mbele yako burudani bora na habari za soka kutoka kila kona ya dunia.</p>
      <div class="d-flex flex-wrap">
        <span class="tag"><i class="fas fa-futbol me-1"></i> Michezo</span>
        <span class="tag"><i class="fas fa-film me-1"></i> Tamthilia</span>
        <span class="tag"><i class="fas fa-newspaper me-1"></i> Habari</span>
        <span class="tag"><i class="fas fa-newspaper me-1"></i> Magazeti</span>
        <span class="tag"><i class="fas fa-broadcast-tower me-1"></i> Moja kwa moja</span>
      </div>
    </div>

    <!-- Reviews and Like -->
    <div class="mt-4 d-flex justify-content-between align-items-center animate__animated animate__fadeIn animate__delay-1s">
      <div>
        <h5 class="section-title">User feedback</h5>
        <p><span class="rating-stars">★★★★★</span> 4.6 average from 2,000+ users</p>
      </div>
      <div>
        <button class="btn btn-outline-primary like-button" id="likeBtn">
          <i class="fas fa-thumbs-up"></i>
          <span id="likeText">Like</span>
          <span id="likeCount">0</span>
        </button>
      </div>
    </div>

    <!-- Testimonials -->
    <div class="mt-4 animate__animated animate__fadeIn animate__delay-1s">
      <h5 class="section-title">What users say</h5>
      <div class="row">
        <div class="col-md-4">
          <div class="feature-card">
            <div class="rating-stars">★★★★★</div>
            <p>"Baila TV ni bora kabisa! Napata mechi zote za Premier League na UEFA."</p>
            <small>- Juma M.</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-card">
            <div class="rating-stars">★★★★☆</div>
            <p>"Tamthilia nzuri sana, naona vipindi vipya kila siku."</p>
            <small>- Neema K.</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="feature-card">
            <div class="rating-stars">★★★★★</div>
            <p>"Habari za soka zinanifikia haraka, nampenda BAILA TV MAX!"</p>
            <small>- Rajab S.</small>
          </div>
        </div>
      </div>
    </div>

    <!-- Data Safety -->
    <div class="mt-4 animate__animated animate__fadeIn animate__delay-1s">
      <h5 class="section-title">Data safety</h5>
      <div class="feature-card">
        <p><strong>Information collected:</strong></p>
        <ul>
          <li><i class="fas fa-map-marker-alt me-2"></i> Location data (to personalize content)</li>
          <li><i class="fas fa-mobile-alt me-2"></i> Device ID (for ads and analytics)</li>
          <li><i class="fas fa-chart-line me-2"></i> App activity (e.g., video views, usage time)</li>
        </ul>
        <p class="mt-3"><i class="fas fa-lock me-2"></i> <small>Data is encrypted and not shared with third parties without user consent.</small></p>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="footer animate__animated animate__fadeIn">
    <div class="container">
      <div class="row">
        <div class="col-md-6">
          <h5>BAILA TV MAX</h5>
          <p>Burudani bora na habari za soka kila siku.</p>
        </div>
        <div class="col-md-6 text-right">
          <p>© 2023 BAILA TV MAX</p>
          <div class="social-icons">
            <a href="#" class="text-white mx-2"><i class="fab fa-facebook-f"></i></a>
            <a href="#" class="text-white mx-2"><i class="fab fa-twitter"></i></a>
            <a href="#" class="text-white mx-2"><i class="fab fa-instagram"></i></a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Screenshot Modal -->
  <div class="modal fade" id="screenshotModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body text-center">
          <img src="" class="modal-img img-fluid" id="modalImage" alt="Screenshot" />
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    $(document).ready(function() {
      // Like button functionality
      let liked = false;
      let likeCount = 0;
      
      $('#likeBtn').click(function() {
        if (!liked) {
          likeCount++;
          $('#likeText').text('Liked');
          $('#likeCount').text(likeCount);
          $(this).addClass('btn-primary').removeClass('btn-outline-primary');
          liked = true;
          
          // Add animation
          $(this).find('i').addClass('animate__animated animate__bounce');
          setTimeout(() => {
            $(this).find('i').removeClass('animate__animated animate__bounce');
          }, 1000);
        } else {
          likeCount--;
          $('#likeText').text('Like');
          $('#likeCount').text(likeCount);
          $(this).addClass('btn-outline-primary').removeClass('btn-primary');
          liked = false;
        }
      });
      
      // Screenshot modal
      $('.screenshot').click(function() {
        const imgSrc = $(this).attr('src');
        $('#modalImage').attr('src', imgSrc);
      });
      
      // Animate elements when they come into view
      $(window).scroll(function() {
        $('.feature-card').each(function() {
          const cardPosition = $(this).offset().top;
          const scrollPosition = $(window).scrollTop() + $(window).height();
          
          if (scrollPosition > cardPosition) {
            $(this).addClass('animate__animated animate__fadeInUp');
          }
        });
      });
      
      // Trigger scroll event on page load
      $(window).trigger('scroll');
    });
  </script>
</body>
</html>